// ============================================================
// TIA Portal V17+ — SCL Source Code
// Pump Pressure Control System — Discrete-Time PID Controller
//
// Block  : FB100  "PumpPressureControl"
// Calling: Must be invoked from OB35 (cyclic interrupt, 100 ms cycle time)
// Author : Mehmet Haydar, I&C Automation Engineer, Germany
// Std    : IEC 61131-3, ISA-5.1
// ============================================================

// ────────────────────────────────────────────────────────────
// 1. INSTANCE DATA BLOCK NOTE  (FB100_DB)
//    The instance DB is created automatically by TIA Portal
//    when the FB is first called. The variables below reside
//    in the STATIC section of the FB and persist between scans.
// ────────────────────────────────────────────────────────────

(*
  STATIC variables (retained across scan cycles):
    integral     : REAL  := 0.0;   // Integral accumulator [error × s]
    prev_error   : REAL  := 0.0;   // Control deviation from previous scan
    first_scan   : BOOL  := TRUE;  // First-execution flag
    pv_filtered  : REAL  := 0.0;   // Low-pass filtered process variable
*)

// ────────────────────────────────────────────────────────────
// 2. FUNCTION BLOCK DECLARATION
// ────────────────────────────────────────────────────────────

FUNCTION_BLOCK "PumpPressureControl"

// ── Interface Variable Declarations ─────────────────────────
VAR_INPUT
    // Operator / SCADA interface
    setpoint    : REAL;         // Pressure setpoint (SP) [bar]
    pv          : REAL;         // Measured process variable from AI transmitter [bar]
    enable      : BOOL;         // Controller enable (TRUE = AUTO mode active)
    manual_mode : BOOL;         // Manual override request from HMI/SCADA
    manual_out  : REAL;         // Manual output value when manual_mode = TRUE [%]

    // PID tuning parameters (adjustable at runtime via HMI)
    Kp          : REAL := 1.2;  // Proportional gain
    Ki          : REAL := 0.5;  // Integral gain [1/s]
    Kd          : REAL := 0.1;  // Derivative gain [s]
    dt          : REAL := 0.1;  // Scan cycle time [s] — must match OB35 period

    // Output limits for the manipulated variable (MV)
    out_min     : REAL := 0.0;   // Minimum controller output (MV low clamp) [%]
    out_max     : REAL := 100.0; // Maximum controller output (MV high clamp) [%]

    // Process alarm thresholds
    pv_high_lim : REAL := 6.0;  // High-pressure alarm setpoint [bar]
    pv_low_lim  : REAL := 0.5;  // Low-pressure alarm setpoint [bar]
END_VAR

VAR_OUTPUT
    control_out   : REAL;       // Controller output — manipulated variable (MV) [%]
    error         : REAL;       // Current control deviation: SP - PV [bar]
    alarm_high    : BOOL;       // High-pressure process alarm (latched with delay)
    alarm_low     : BOOL;       // Low-pressure process alarm (latched with delay)
    alarm_fault   : BOOL;       // Transmitter fault — PV out of valid range
    status_word   : WORD;       // Controller status register for HMI/SCADA
END_VAR

VAR_IN_OUT
    // External-resettable accumulator (operator reset via HMI)
    total_run_time : DINT;      // Cumulative pump operating time [OB35 scan counts]
END_VAR

VAR
    // --- PID internal state (static, retained between scans) ---
    integral       : REAL := 0.0;    // Integral accumulator
    prev_error     : REAL := 0.0;    // Previous scan control deviation
    first_scan     : BOOL := TRUE;   // Suppresses derivative spike on first execution

    // --- Intermediate calculation variables ---
    P_term         : REAL;           // Proportional contribution
    I_term         : REAL;           // Integral contribution
    D_term         : REAL;           // Derivative contribution
    raw_output     : REAL;           // Unsaturated PID sum before output clamping
    d_error        : REAL;           // Derivative of control deviation

    // --- Anti-windup flag ---
    output_clamped : BOOL;           // TRUE when MV is saturated at output limit

    // --- First-order low-pass filter for PV noise rejection ---
    pv_filtered    : REAL;
    filter_alpha   : REAL := 0.85;   // Filter coefficient α ∈ [0,1]; higher = more filtering

    // --- Alarm debounce counters (prevent false trips on noise) ---
    high_alarm_cnt : INT := 0;
    low_alarm_cnt  : INT := 0;
    ALARM_DELAY    : INT := 5;       // Required consecutive scans before alarm trips (5 × 100 ms = 500 ms)
END_VAR


// ────────────────────────────────────────────────────────────
// 3. PROGRAM BODY
//    Execution sequence mirrors ISA-18.2 alarm hierarchy:
//      1. PV validation  →  2. PV filtering  →  3. Mode selection
//      →  4. Enable check  →  5. PID computation  →  6. Anti-windup
//      →  7. Alarm evaluation  →  8. Status register update
// ────────────────────────────────────────────────────────────
BEGIN

    // ── 3.1 Process Variable (PV) Range Validation ──────────
    // If the transmitter signal is outside the physical instrument range,
    // declare a fault, force output to 0%, and return immediately.
    IF (pv < -0.5) OR (pv > 15.0) THEN
        alarm_fault  := TRUE;
        control_out  := 0.0;
        status_word  := W#16#0080;   // Bit 7 = FAULT
        RETURN;
    ELSE
        alarm_fault := FALSE;
    END_IF;

    // ── 3.2 First-Order Low-Pass Filter on PV ───────────────
    // Discrete filter equation: y[k] = α·y[k-1] + (1-α)·x[k]
    // Reduces high-frequency measurement noise before PID computation.
    IF first_scan THEN
        pv_filtered := pv;   // Initialize filter state — no history on first scan
    ELSE
        pv_filtered := filter_alpha * pv_filtered + (1.0 - filter_alpha) * pv;
    END_IF;

    // ── 3.3 Operating Mode Selection ────────────────────────
    // MANUAL mode: pass through the operator-commanded output directly.
    // Integral tracking is maintained to ensure bumpless transfer
    // back to AUTO mode (pre-loads integral so output is continuous).
    IF manual_mode THEN
        control_out := manual_out;
        integral    := manual_out / Ki;   // Integral pre-load for bumpless AUTO transfer
        status_word := W#16#0002;         // Bit 1 = MANUAL
        RETURN;
    END_IF;

    // ── 3.4 Controller Enable Check ─────────────────────────
    // When disabled, drive output to 0%, reset integral accumulator,
    // and assert first_scan so the derivative term reinitializes on next enable.
    IF NOT enable THEN
        control_out := 0.0;
        integral    := 0.0;
        first_scan  := TRUE;
        status_word := W#16#0000;   // IDLE / disabled
        RETURN;
    END_IF;

    // ── 3.5 PID Control Law Computation ─────────────────────

    // Control deviation: e[k] = SP - PV_filtered
    error := setpoint - pv_filtered;

    // Proportional term: P = Kp · e[k]
    P_term := Kp * error;

    // Integral term: pre-accumulate before anti-windup correction
    // I[k] = I[k-1] + Ki · e[k] · dt
    integral := integral + error * dt;
    I_term   := Ki * integral;

    // Derivative term: computed on error signal (not PV) to avoid
    // derivative kick on setpoint step changes.
    // First-scan protection: D = 0 on initial execution cycle.
    IF first_scan THEN
        D_term     := 0.0;
        first_scan := FALSE;
    ELSE
        d_error := (error - prev_error) / dt;   // Finite difference approximation
        D_term  := Kd * d_error;
    END_IF;
    prev_error := error;

    // Unsaturated controller output: u[k] = P + I + D
    raw_output := P_term + I_term + D_term;

    // ── 3.6 Output Clamping with Anti-Windup ────────────────
    // Back-calculation anti-windup: if the raw output saturates,
    // undo the most recent integral increment to prevent integrator wind-up.
    output_clamped := FALSE;

    IF raw_output > out_max THEN
        control_out    := out_max;
        output_clamped := TRUE;
    ELSIF raw_output < out_min THEN
        control_out    := out_min;
        output_clamped := TRUE;
    ELSE
        control_out := raw_output;
    END_IF;

    // Revert last integration step when output is clamped
    IF output_clamped THEN
        integral := integral - error * dt;
    END_IF;

    // ── 3.7 Process Alarm Evaluation (ISA-18.2 with debounce) ──
    // Alarms require ALARM_DELAY consecutive qualifying scans before activating.
    // This prevents nuisance trips from transient measurement noise.

    // High-pressure alarm: PV exceeds upper threshold
    IF pv_filtered >= pv_high_lim THEN
        high_alarm_cnt := high_alarm_cnt + 1;
    ELSE
        high_alarm_cnt := 0;   // Reset counter on non-qualifying scan
    END_IF;
    alarm_high := (high_alarm_cnt >= ALARM_DELAY);

    // Low-pressure alarm: PV below lower threshold while pump is commanded on
    // Condition guard (control_out > 20%) prevents spurious low-pressure alarm on startup
    IF enable AND (control_out > 20.0) AND (pv_filtered <= pv_low_lim) THEN
        low_alarm_cnt := low_alarm_cnt + 1;
    ELSE
        low_alarm_cnt := 0;
    END_IF;
    alarm_low := (low_alarm_cnt >= ALARM_DELAY);

    // ── 3.8 Pump Operating Time Accumulator ─────────────────
    // Incremented every OB35 scan while the pump is running (MV > 0%).
    // Useful for predictive maintenance scheduling.
    IF enable AND (control_out > 0.0) THEN
        total_run_time := total_run_time + 1;   // Each count = one OB35 scan = 0.1 s
    END_IF;

    // ── 3.9 Controller Status Register (HMI / SCADA) ────────
    // Encodes operating mode and alarm states in a single WORD for
    // efficient transport over PROFINET/OPC-UA to the HMI/SCADA system.
    //
    //   Bit 0 : AUTO mode active
    //   Bit 1 : MANUAL mode active
    //   Bit 2 : ALARM_HIGH active
    //   Bit 3 : ALARM_LOW active
    //   Bit 7 : FAULT (transmitter out of range)
    status_word := W#16#0001;   // Default: AUTO
    IF alarm_high THEN
        status_word := status_word OR W#16#0004;
    END_IF;
    IF alarm_low THEN
        status_word := status_word OR W#16#0008;
    END_IF;

END_FUNCTION_BLOCK


// ────────────────────────────────────────────────────────────
// 4. OB35 — CYCLIC INTERRUPT ORGANIZATION BLOCK (100 ms)
//    This OB calls FB100 on every cyclic interrupt execution.
//    OB35 period must match the dt parameter passed to FB100.
// ────────────────────────────────────────────────────────────

ORGANIZATION_BLOCK "CyclicInterrupt" [OB35]

VAR_TEMP
    dummy : INT;
END_VAR

BEGIN
    // Invoke FB100 using its instance DB (PumpPressureControl_DB / DB100)
    "PumpPressureControl_DB"(
        setpoint    := "DB_HMI".pressure_setpoint,   // Operator setpoint from HMI [bar]
        pv          := "DB_IO".AI_pressure_bar,       // Scaled AI from pressure transmitter [bar]
        enable      := "DB_HMI".pump_enable,          // Pump enable command from HMI
        manual_mode := "DB_HMI".manual_mode,          // Manual mode request from HMI
        manual_out  := "DB_HMI".manual_output,        // Manual output value from HMI [%]
        Kp          := 1.2,
        Ki          := 0.5,
        Kd          := 0.1,
        dt          := 0.1,                           // Scan cycle time = OB35 period [s]
        out_min     := 0.0,
        out_max     := 100.0,
        pv_high_lim := 6.0,
        pv_low_lim  := 0.5,
        control_out  => "DB_IO".AO_pump_speed_pct,   // MV to VFD speed reference [%]
        error        => "DB_HMI".pid_error,           // Control deviation for HMI display
        alarm_high   => "AlarmDB".pump_pressure_high,
        alarm_low    => "AlarmDB".pump_pressure_low,
        alarm_fault  => "AlarmDB".pump_pressure_fault,
        status_word  => "DB_HMI".pid_status,
        total_run_time := "DB_HMI".pump_run_time
    );

    // Scale AO output: 0–100 % → 0–27648 (Siemens S7 16-bit analog raw value)
    // Corresponds to 4–20 mA on analog output module to VFD
    "DB_IO".AO_pump_raw :=
        REAL_TO_INT("DB_IO".AO_pump_speed_pct / 100.0 * 27648.0);

END_ORGANIZATION_BLOCK


// ────────────────────────────────────────────────────────────
// 5. HARDWARE WIRING & INTEGRATION NOTES
// ────────────────────────────────────────────────────────────
(*
  FIELD INSTRUMENT CONNECTIONS
  ─────────────────────────────
  AI_pressure_bar  : Pressure transmitter, 4–20 mA loop, range 0–10 bar
                     PLC tag scaling: raw 0 = 0 bar, raw 27648 = 10 bar
  AO_pump_raw      : Variable-frequency drive (VFD) speed reference input
                     raw 0 = 0%, raw 27648 = 100% (4–20 mA analog output module)

  OB35 CYCLE TIME
  ────────────────
  Default OB35 period: 100 ms — must match dt = 0.1 s in FB100 call.
  To change the scan rate, update both the OB35 period property
  and the dt input parameter accordingly.

  BUMPLESS TRANSFER (MANUAL → AUTO)
  ───────────────────────────────────
  While in MANUAL mode, the integral accumulator tracks the manual output:
    integral := manual_out / Ki
  When the operator switches back to AUTO, the integral is pre-loaded
  so the controller output is continuous — eliminating the bump.

  TIA PORTAL PROJECT BLOCK STRUCTURE
  ────────────────────────────────────
  Program blocks/
    FB100 — PumpPressureControl       (this file)
    DB100 — PumpPressureControl_DB    (instance DB — auto-generated)
    DB101 — DB_HMI                    (HMI shared data block)
    DB102 — DB_IO                     (I/O tag mirror data block)
    OB35  — CyclicInterrupt           (100 ms cyclic task)
*)
